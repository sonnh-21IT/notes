# Supabase (required for app + /admin)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GitHub Pages project site (repo "notes" → https://user.github.io/notes/)
# Local dev omits this (defaults to /). CI sets VITE_BASE_PATH=/notes/
# VITE_BASE_PATH=/notes/

# Content-admin login (/admin) — dedicated Auth user, NOT the Supabase project owner:
# 1. Authentication → Users → Add user (email + password)
# 2. Copy User UID into is_content_admin() in supabase/schema.sql (both places)
# 3. Run schema.sql (or the Upgrade section) in the SQL editor
# 4. Authentication → Providers: disable public sign-up
# 5. Create Storage policies via schema (bucket note-covers)
# See README → Setup / Security

# Service role — only for npm run sync:supabase (never VITE_*, never commit)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
