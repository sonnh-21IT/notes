# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin (/admin/login):
# - Vào Authentication → Users: Add user, đặt password
# - Quên password: Users → ⋯ → Reset password
# - Chạy supabase/schema.sql + npm run sync:supabase

# Service role key — required for npm run sync:supabase (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
