# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GitHub Pages project site (repo "notes" → https://user.github.io/notes/)
# Local dev omits this (defaults to /). CI sets VITE_BASE_PATH=/notes/
# VITE_BASE_PATH=/notes/

# Admin (/admin/login):
# - Vào Authentication → Users: Add user, đặt password
# - Quên password: Users → ⋯ → Reset password
# - Chạy supabase/schema.sql + npm run sync:supabase

# Service role key — required for npm run sync:supabase (NOT the anon key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
