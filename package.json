    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.6.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
